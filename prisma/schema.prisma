generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketplaces Marketplace[]
}

model Marketplace {
  id               String   @id @default(cuid())
  name             String
  baseUrl          String
  platform         String   @default("wordpress")

  wpUsername       String?
  wpAppPasswordEnc String?  @db.Text

  connectionStatus String   @default("unknown") // unknown | connected | failed
  lastCheckedAt    DateTime?

  // ==============================
  // 🔥 CRM CONFIG (NEW)
  // ==============================

  leadCpt              String?   // ce CPT urmarim pentru leads
  crmReady             Boolean   @default(false)
  crmStatus            String    @default("not_configured") // not_configured | ready | missing_fields
  autoSyncEnabled      Boolean   @default(true)
  lastSyncAt           DateTime?

  // ==============================

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
