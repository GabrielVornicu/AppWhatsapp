generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketplaces Marketplace[]
}

model Marketplace {
  id               String   @id @default(cuid())
  name             String
  baseUrl          String
  platform         String   @default("wordpress")

  wpUsername       String?
  wpAppPasswordEnc String?  @db.Text

  connectionStatus String   @default("unknown") // unknown | connected | failed
  lastCheckedAt    DateTime?

  // ==============================
  // 🔥 CRM CONFIG
  // ==============================

  leadCpt              String?
  crmReady             Boolean   @default(false)
  crmStatus            String    @default("not_configured") // not_configured | ready | missing_fields
  autoSyncEnabled      Boolean   @default(true)
  lastSyncAt           DateTime?

  // ==============================

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id])

  fields           MarketplaceField[]

  @@index([createdById])
}

model MarketplaceField {
  id              String   @id @default(cuid())

  marketplaceId   String
  marketplace     Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  wpKey           String   // ex: crm_phone, titlu, localitate
  label           String   // ex: Telefon client
  fieldType       String   @default("string") // string | number | boolean | date

  isVisible       Boolean  @default(true)
  isEditable      Boolean  @default(false)
  isFilterable    Boolean  @default(true)

  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([marketplaceId])
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
