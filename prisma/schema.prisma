generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketplaces Marketplace[]
}

model Marketplace {
  id               String   @id @default(cuid())
  name             String
  baseUrl          String
  platform         String   @default("wordpress")

  wpUsername       String?
  wpAppPasswordEnc String?  @db.Text

  connectionStatus String   @default("unknown")
  lastCheckedAt    DateTime?

  // CRM CONFIG
  leadCpt          String?
  crmReady         Boolean   @default(false)
  crmStatus        String    @default("not_configured")
  autoSyncEnabled  Boolean   @default(true)
  lastSyncAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id])

  fields           MarketplaceField[]
  leads            Lead[]
  templates        MessageTemplate[]
  queueItems       MessageQueue[]

  @@index([createdById])
}

model MarketplaceField {
  id              String   @id @default(cuid())

  marketplaceId   String
  marketplace     Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  wpKey           String
  label           String
  fieldType       String   @default("string")

  isVisible       Boolean  @default(true)
  isEditable      Boolean  @default(false)
  isFilterable    Boolean  @default(true)

  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([marketplaceId])
}

model Lead {
  id                String   @id @default(cuid())

  marketplaceId     String
  marketplace       Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  wpPostId          BigInt
  phone             String

  crmStatus         String   @default("NEW")
  inSequence        Boolean  @default(false)
  currentStep       Int      @default(0)
  lastSentAt        DateTime?
  lastReplyAt       DateTime?

  isClient          Boolean  @default(false)
  doNotContact      Boolean  @default(false)
  hideFromListing   Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  queueItems        MessageQueue[]

  @@index([marketplaceId])
  @@index([wpPostId])
  @@index([phone])
}

model MessageTemplate {
  id              String   @id @default(cuid())

  marketplaceId   String
  marketplace     Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  name            String
  channel         String   @default("whatsapp")
  variantType     String   @default("non_client")
  content         String   @db.Text

  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([marketplaceId])
}

model MessageQueue {
  id              String   @id @default(cuid())

  marketplaceId   String
  marketplace     Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  templateId      String?

  channel         String   @default("whatsapp")
  content         String   @db.Text

  status          String   @default("queued")
  scheduledAt     DateTime
  sentAt          DateTime?

  attemptCount    Int      @default(0)
  errorMessage    String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([marketplaceId])
  @@index([leadId])
  @@index([status])
  @@index([scheduledAt])
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
